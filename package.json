{
  "name": "the-citizen-audit",
  "version": "1.0.0-rc1",
  "private": false,
  "scripts": {
    "agent:hygiene": "node scripts/content-hygiene-agent.js",
    "agent:release": "node scripts/release-steward-agent.js",
    "guardian:constitution": "node guardians/constitution/check.js",
    "proposal:status": "node proposals/status.js",
    "memory:export": "node memory/export.js",
    "memory:query": "node memory/query.js",
    "memory:status": "node memory/status.js",
    "executive:status": "node kernel/executive/status.js",
    "agent:ads": "node scripts/ads-steward-agent.js",
    "agent:ads:dry": "node scripts/ads-steward-agent.js --dry-run",
    "agent:publication": "node scripts/publication-builder-agent.js",
    "agent:publication:dry": "node scripts/publication-builder-agent.js --dry-run",
    "agent:repair": "node scripts/repair-agent.js",
    "agent:repair:dry": "node scripts/repair-agent.js --dry-run",
    "agent:sources": "node scripts/source-steward-agent.js",
    "agents:list": "node -e \"const r=require('./agents/registry.json'); for (const a of r.agents) console.log(`${a.id} | ${a.status} | L${a.authorityLevel} | ${(a.capabilities||[]).join(',')} | ${a.command}`)\"",
    "authority:check": "node kernel/authority/engine.js",
    "execution:test": "node --test tests/execution-ledger.test.js tests/execution-recovery.test.js tests/execution-orchestrator.test.js tests/runtime-integration.test.js tests/runtime-isolation.test.js tests/event-projection.test.js tests/bypass-audit.test.js",
    "execution:verify": "node kernel/execution/ledger.js verify",
    "registry:validate": "node kernel/registry/validate.js",
    "kernel:run": "node kernel/runtime/run.js",
    "kernel:run-all": "node kernel/runtime/run.js --all",
    "kernel:run-all:dry": "node kernel/runtime/run.js --all --dry-run",
    "kernel:status": "node kernel/runtime/status.js",
    "ads:export": "node scripts/export-ads.js",
    "ads:validate": "node scripts/validate-ads.js",
    "ads:sync": "npm run ads:export && npm run ads:validate",
    "archive:assistant": "node scripts/archive-assistant-launch.js",
    "archive:helper": "node scripts/archive-assistant-helper.js",
    "archive:manifest": "node scripts/archive-manifest-generator.js",
    "archive:manifest:test": "node --test tests/archive-manifest-generator.test.js tests/archive-assistant-validation.test.js tests/archive-assistant-export.test.js tests/archive-assistant-helper.test.js tests/archive-assistant-wayback.test.js",
    "archive:serve": "node scripts/archive-assistant-serve.js",
    "build:publication": "node scripts/build-publication-assets.js",
    "qa": "node scripts/qa.js",
    "release:rc": "node scripts/release-candidate.js",
    "archive:hash": "node scripts/archive-batch.js",
    "deploy": "wrangler deploy",
    "execution:run": "node kernel/execution/run.js",
    "phase4:test": "node --test tests/runtime-integration.test.js tests/runtime-isolation.test.js tests/event-projection.test.js tests/bypass-audit.test.js",
    "runtime:integration:test": "node --test tests/runtime-integration.test.js",
    "runtime:transactional": "node kernel/runtime/run-transactional.js",
    "events:test": "node --test tests/event-projection.test.js",
    "events:project": "node scripts/project-execution-events.js",
    "bypass:audit": "node scripts/bypass-audit.js",
    "bypass:audit:test": "node --test tests/bypass-audit.test.js",
    "tamper:test": "node --test --test-name-pattern=\"tamper\" tests/event-projection.test.js tests/execution-orchestrator.test.js",
    "fault:test": "node --test --test-name-pattern=\"rollback|recovery_required|crash|failure|restor|unavailable|cleanup\" tests/runtime-integration.test.js tests/runtime-isolation.test.js tests/execution-orchestrator.test.js",
    "execution:verify:full": "npm run execution:test && npm run archive:manifest:test && npm run bypass:audit && npm run qa",
    "runtime:isolation:test": "node --test tests/runtime-isolation.test.js"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}
