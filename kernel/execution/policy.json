{
  "version": "1.1.0",
  "updated": "2026-07-07",
  "principle": "Execution applies only approved, declared, policy-authorized writes and succeeds only after institutional validation.",
  "warningPolicy": "nonfatal",
  "requireAffectedObjectCoverage": true,
  "requiredValidators": [
    "execution-plan",
    "exact-materialization",
    "institution-registry",
    "dependency-graph"
  ],
  "prohibitedPaths": [
    "package.json",
    "kernel/VERSION.md"
  ],
  "prohibitedPrefixes": [
    ".git/",
    "agents/",
    "audits/",
    "docs/adr/",
    "docs/institution-os/",
    "institution/",
    "kernel/authority/",
    "kernel/execution/",
    "kernel/permissions/",
    "kernel/registry/",
    "kernel/transactions/",
    "schemas/"
  ],
  "actions": {
    "write_report": {
      "allowedPaths": [
        "docs/repair-agent-report.md"
      ],
      "allowedPrefixes": [
        "docs/agent-reports/"
      ],
      "allowDelete": false,
      "semanticValidators": [
        "write-report-semantics"
      ]
    },
    "regenerate_derived_files": {
      "allowedPaths": [
        "public/audits.html"
      ],
      "allowedPrefixes": [
        "public/data/"
      ],
      "allowDelete": false,
      "semanticValidators": [
        "derived-files-semantics"
      ]
    },
    "export_ads_records": {
      "allowedPaths": [],
      "allowedPrefixes": [
        "public/data/"
      ],
      "allowDelete": false,
      "semanticValidators": [
        "ads-records-semantics"
      ]
    },
    "sort_registry": {
      "allowedPaths": [
        "registry/audits.json"
      ],
      "allowedPrefixes": [],
      "allowDelete": false,
      "semanticValidators": [
        "sort-registry-semantics"
      ]
    }
  }
}
