{
  "version": "2.0.0",
  "updated": "2026-07-06",
  "principle": "Execution applies only approved, declared, policy-authorized writes and succeeds only after institutional validation.",
  "requireAffectedObjectCoverage": true,
  "requiredValidators": [
    "execution-plan",
    "institution-registry",
    "dependency-cycles",
    "exact-materialization"
  ],
  "prohibitedPaths": [
    "package.json",
    "kernel/VERSION.md"
  ],
  "prohibitedPrefixes": [
    ".git/",
    "agents/",
    "audits/",
    "docs/adr/",
    "docs/institution-os/",
    "institution/",
    "kernel/authority/",
    "kernel/execution/",
    "kernel/permissions/",
    "kernel/registry/",
    "kernel/transactions/",
    "schemas/"
  ],
  "actions": {
    "write_report": {
      "allowedPaths": ["docs/repair-agent-report.md"],
      "allowedPrefixes": ["docs/agent-reports/"],
      "allowDelete": false,
      "semanticValidators": []
    },
    "regenerate_derived_files": {
      "allowedPaths": ["public/audits.html"],
      "allowedPrefixes": ["public/data/"],
      "allowDelete": false,
      "semanticValidators": []
    },
    "export_ads_records": {
      "allowedPaths": [],
      "allowedPrefixes": ["public/data/"],
      "allowDelete": false,
      "semanticValidators": []
    },
    "sort_registry": {
      "allowedPaths": ["registry/audits.json"],
      "allowedPrefixes": [],
      "allowDelete": false,
      "semanticValidators": []
    }
  }
}
