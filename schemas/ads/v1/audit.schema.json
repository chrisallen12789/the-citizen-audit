{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecitizenaudit.org/schemas/ads/v1/audit.schema.json",
  "title": "ADS v1 Audit Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "adsVersion",
    "title",
    "status",
    "version",
    "summary",
    "created",
    "updated",
    "permalink"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^AUD-[0-9]{3}$" },
    "legacyId": { "type": "string", "pattern": "^AUDIT-[0-9]+$" },
    "numericId": { "type": "string", "pattern": "^[0-9]{3}$" },
    "adsVersion": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "review", "published", "superseded", "withdrawn"]
    },
    "version": { "type": "string", "minLength": 1 },
    "classification": {
      "type": "string",
      "enum": ["public", "internal", "restricted"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "published": { "type": "string", "format": "date" },
    "permalink": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "records": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claims": { "type": "string" },
        "sources": { "type": "string" },
        "decisions": { "type": "string" },
        "unknowns": { "type": "string" },
        "revisions": { "type": "string" },
        "downloads": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claims": { "type": "integer", "minimum": 0 },
        "sources": { "type": "integer", "minimum": 0 },
        "decisions": { "type": "integer", "minimum": 0 },
        "unknowns": { "type": "integer", "minimum": 0 },
        "downloads": { "type": "integer", "minimum": 0 }
      }
    },
    "institutionalRules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
