{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecitizenaudit.org/schemas/platform-finding.schema.json",
  "title": "Citizen Audit Platform Finding Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "findingId",
    "auditId",
    "sequence",
    "slug",
    "title",
    "claimIds",
    "materiality",
    "confidence",
    "confidenceRationale",
    "evidenceStatus",
    "supportingSourceIds"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "findingId": { "type": "string", "pattern": "^TCA-[A-Z0-9]+-[0-9]{4}-[0-9]{3}-F[0-9]{2}$" },
    "auditId": { "type": "string", "pattern": "^TCA-[A-Z0-9]+-[0-9]{4}-[0-9]{3}$" },
    "sequence": { "type": "integer", "minimum": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "explanation": { "type": "string" },
    "claimIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^CLAIM-[0-9]{6}$" }
    },
    "materiality": { "enum": ["critical", "major", "moderate", "minor", "contextual"] },
    "confidence": { "enum": ["high", "moderate", "limited", "indeterminate"] },
    "confidenceRationale": { "type": "string", "minLength": 1 },
    "evidenceStatus": { "enum": ["supported", "supported_with_limitations", "partially_supported", "unsupported", "indeterminate"] },
    "supportingSourceIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SRC-[0-9]{6}$" }
    },
    "qualifyingSourceIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^SRC-[0-9]{6}$" }
    },
    "calculationIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^CALC-[0-9]{6}$" }
    },
    "unknownIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^UNK-[0-9]{6}$" }
    },
    "challengeIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^CH-[0-9]{4}-[0-9]{6}$" }
    },
    "correctionIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^COR-[0-9]{4}-[0-9]{6}$" }
    }
  }
}
