{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecitizenaudit.org/schemas/execution-exclusive-boundary.schema.json",
  "title": "Institution OS Exclusive Execution Boundary",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "attemptId", "token", "pid", "hostname", "acquiredAt"],
  "properties": {
    "version": { "const": "1.0.0" },
    "attemptId": { "type": "string", "pattern": "^ATTEMPT-[A-Z0-9][A-Z0-9-]{2,63}$" },
    "token": { "type": "string", "minLength": 1 },
    "pid": { "type": "integer", "minimum": 0 },
    "hostname": { "type": "string", "minLength": 1 },
    "acquiredAt": { "type": "string", "format": "date-time" }
  }
}
