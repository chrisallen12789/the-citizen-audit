{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thecitizenaudit.org/schemas/platform-calculation.schema.json",
  "title": "Citizen Audit Platform Calculation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "calculationId",
    "title",
    "purpose",
    "formula",
    "inputs",
    "result",
    "findingIds",
    "verificationStatus"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "calculationId": { "type": "string", "pattern": "^CALC-[0-9]{6}$" },
    "title": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "formula": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "unit", "sourceId"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": ["number", "string"] },
          "unit": { "type": "string", "minLength": 1 },
          "period": { "type": "string" },
          "sourceId": { "type": "string", "pattern": "^SRC-[0-9]{6}$" },
          "sourceLocation": { "type": "string" }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "exclusions": { "type": "array", "items": { "type": "string" } },
    "rounding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": { "enum": ["none", "half_up", "half_even", "floor", "ceiling"] },
        "decimalPlaces": { "type": "integer", "minimum": 0 }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": { "type": ["number", "string"] },
        "unit": { "type": "string", "minLength": 1 }
      }
    },
    "findingIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^TCA-[A-Z0-9]+-[0-9]{4}-[0-9]{3}-F[0-9]{2}$" }
    },
    "artifactIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^ART-[0-9]{6}$" }
    },
    "verificationStatus": { "enum": ["verified", "pending", "failed", "superseded"] }
  }
}
